# Local development defaults. Copy to `.env` and change local-only values.
# Do not commit `.env`; production secrets must come from the deployment environment.

APP_PORT=18080

POSTGRES_DB=tripledger
POSTGRES_USER=tripledger
POSTGRES_PASSWORD=replace-with-local-dev-password

TRIPLEDGER_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:18080
TRIPLEDGER_LOG_LEVEL=INFO
